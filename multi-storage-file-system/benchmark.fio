nrfiles=80
numjobs=4
bs=4Ki
filesize=1Gi
size=1Gi
io_size=20Gi

[P3.8]
; 80 x 1 GiB files, 4K seq read, 8 threads
rw=read
nrfiles=80
numjobs=8
bs=4Ki
filesize=1Gi
size=1Gi
io_size=10Gi

